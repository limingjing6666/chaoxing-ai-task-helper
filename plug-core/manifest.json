{
  "manifest_version": 3,
  "name": "超星AI助手",
  "version": "1.3.0",
  "description": "超星学习通 AI 实践与主题讨论自动完成助手，支持批量执行、自动重试与评估反馈驱动优化",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://api.deepseek.com/*",
    "https://*.chaoxing.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://mooc2-ans.chaoxing.com/ai-evaluate/*",
        "*://mooc2-ans.chaoxing.com/mooc2-ans/ai-evaluate/*"
      ],
      "js": ["page-inject.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["*://mobilelearn.chaoxing.com/page/active/stuActiveList*"],
      "js": ["task-page-inject.js"],
      "run_at": "document_idle",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "*://mobilelearn.chaoxing.com/*",
        "*://mooc1-api.chaoxing.com/*",
        "*://mooc2-ans.chaoxing.com/*",
        "*://mooc1.chaoxing.com/*",
        "*://groupweb.chaoxing.com/*"
      ],
      "js": ["discuss-inject.js"],
      "run_at": "document_idle",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "*://mobilelearn.chaoxing.com/*",
        "*://mooc1-api.chaoxing.com/*",
        "*://mooc2-ans.chaoxing.com/*",
        "*://mooc1.chaoxing.com/*",
        "*://groupweb.chaoxing.com/*"
      ],
      "js": ["cxai-constants.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
